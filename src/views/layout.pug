doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Fotaza2 - #{title}
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css")
    style.
      body {
        background-color: #1e1e2f;
        color: #e0e0e0;
        min-height: 100vh;
      }
      .navbar-custom {
        background-color: #12122a;
        border-bottom: 1px solid #2c2c3e;
      }
      .navbar-brand {
        color: #00bfff !important;
        font-weight: bold;
        font-size: 1.5rem;
      }
      .nav-link {
        color: #aaa !important;
      }
      .nav-link:hover {
        color: #00bfff !important;
      }
      .card-custom {
        background-color: #2c2c3e;
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
      }
      .btn-primary-custom {
        background-color: #00bfff;
        border: none;
        color: white;
      }
      .btn-primary-custom:hover {
        background-color: #009acd;
        color: white;
      }
      .text-accent {
        color: #00bfff;
      }
      .form-control, .form-select {
        background-color: #3a3a50;
        border: 1px solid #4a4a60;
        color: white;
      }
      .form-control:focus, .form-select:focus {
        background-color: #3a3a50;
        border-color: #00bfff;
        color: white;
        box-shadow: 0 0 0 0.2rem rgba(0,191,255,0.25);
      }
      .form-control::placeholder {
        color: #888;
      }
      .badge-licencia {
        font-size: 0.75rem;
      }
      .badge {
        color: white !important;
      }
  body
    nav.navbar.navbar-expand-lg.navbar-custom
      .container
        a.navbar-brand(href="/posts/feed")
          i.bi.bi-camera-fill.me-2

        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navMenu")
          span.navbar-toggler-icon
        #navMenu.collapse.navbar-collapse
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href="/posts/feed")
                i.bi.bi-house-fill.me-1

            li.nav-item
              a.nav-link(href="/posts/create")
                i.bi.bi-plus-circle.me-1

            li.nav-item
              a.nav-link(href="/notifications")
                i.bi.bi-bell-fill.me-1

            li.nav-item
              a.nav-link(href="/collections")
                i.bi.bi-collection-fill.me-1

            li.nav-item
              a.nav-link(href="/interests")
                i.bi.bi-heart-fill.me-1

            li.nav-item
              a.nav-link(href="/logout")
                i.bi.bi-box-arrow-right.me-1
                                

    .container.py-4
      block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")