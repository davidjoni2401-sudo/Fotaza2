doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Fotaza2 - Registro
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css")
    style.
      body {
        background-color: #1e1e2f;
        color: white;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .card {
        background-color: #2c2c3e;
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.5);
      }
      .form-control {
        background-color: #3a3a50;
        border: 1px solid #4a4a60;
        color: white;
      }
      .form-control:focus {
        background-color: #3a3a50;
        border-color: #00bfff;
        color: white;
        box-shadow: 0 0 0 0.2rem rgba(0,191,255,0.25);
      }
      .form-control::placeholder { color: #888; }
      .btn-accent {
        background-color: #00bfff;
        border: none;
        color: white;
        width: 100%;
      }
      .btn-accent:hover { background-color: #009acd; color: white; }
      .brand { color: #00bfff; font-size: 2rem; font-weight: bold; }
  body
    .card.p-4(style="width: 360px")
      .text-center.mb-4
        i.bi.bi-camera-fill(style="font-size:2.5rem;color:#00bfff")
        h2.brand Fotaza2
        p.text-muted Creá tu cuenta
      form(action="/register" method="POST")
        .mb-3
          label.form-label Nombre
          input.form-control(type="text" name="nombre" placeholder="Tu nombre" required)
        .mb-3
          label.form-label Email
          input.form-control(type="email" name="email" placeholder="tu@email.com" required)
        .mb-3
          label.form-label Contraseña
          input.form-control(type="password" name="password" placeholder="••••••••" required)
        button.btn.btn-accent.mb-3(type="submit") Registrarse
        .text-center
          span.text-muted ¿Ya tenés cuenta?
          a.ms-1(href="/login" style="color:#00bfff") Iniciá sesión
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")