doctype html
doctype html
html
  head
    title Feed

    style.
      body {
        background-color: #1e1e2f;
        font-family: Arial, sans-serif;
        color: white;
        margin: 0;
        padding: 20px;
      }

      h1 {
        text-align: center;
        color: #00bfff;
      }

      .post {
        background-color: #2c2c3e;
        padding: 20px;
        border-radius: 10px;
        margin: 20px auto;
        width: 400px;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
      }

      img {
        width: 100%;
        border-radius: 10px;
        margin-top: 10px;
      }

      p {
        margin-top: 10px;
      }

      h3 {
        color: #00bfff;
      }

      h4 {
        margin-top: 20px;
        color: #00d4ff;
      }

      .comment {
        background-color: #3a3a50;
        padding: 10px;
        border-radius: 5px;
        margin-top: 8px;
      }

      input[type="text"] {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        border: none;
        border-radius: 5px;
      }

      button {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        background-color: #00bfff;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
      }

      button:hover {
        background-color: #009acd;
      }

  body

    h1 Feed de Publicaciones

    each post in posts

      .post

        h3= post.nombre

        img(src=`/uploads/${post.imagen}`)

        p= post.descripcion

        h4 Comentarios

        if post.comments

          each comment in post.comments

            .comment

              p
                b #{comment.nombre}:
                |  #{comment.comentario}
         

        form(action="/posts/comment" method="POST")

          input(
            type="hidden"
            name="post_id"
            value=post.id
          )

          input(
            type="text"
            name="comentario"
            placeholder="Escribí un comentario"
          )

          button(type="submit") Comentar