extends layout

block content
  h1.text-center.text-accent.mb-4(style="color:#00bfff")
    i.bi.bi-images.me-2
    | Publicaciones

  form.card.card-custom.p-3.mb-4(action="/posts/feed" method="GET")
    .row.g-2
      .col-lg-5
        input.form-control(type="text" name="busqueda" value=busqueda placeholder="Buscar por título, descripción, etiqueta o usuario...")
      .col-sm-4.col-lg-2
        if sessionUser
          select.form-select(name="licencia")
            option(value="" selected=!filters.licencia) Todas las licencias
            option(value="sin copyright" selected=filters.licencia === "sin copyright") Sin copyright
            option(value="con copyright" selected=filters.licencia === "con copyright") Con copyright
        else
          select.form-select(disabled)
            option Sin copyright
      .col-sm-4.col-lg-2
        select.form-select(name="valoracionMinima")
          option(value="0" selected=filters.valoracionMinima === 0) Cualquier valoración
          option(value="3" selected=filters.valoracionMinima === 3) 3 estrellas o más
          option(value="4" selected=filters.valoracionMinima === 4) 4 estrellas o más
      .col-sm-4.col-lg-2
        select.form-select(name="orden")
          option(value="destacadas" selected=filters.orden === "destacadas") Destacadas
          option(value="recientes" selected=filters.orden === "recientes") Más recientes
          option(value="valoradas" selected=filters.orden === "valoradas") Mejor valoradas
      .col-lg-1.d-grid
        button.btn.btn-primary-custom(type="submit" title="Buscar" aria-label="Buscar")
          i.bi.bi-search
    if !sessionUser
      small.text-muted.mt-2 El contenido con copyright requiere iniciar sesión.

  each post in posts
    .card.card-custom.mb-4.mx-auto(style="max-width: 600px")
      .card-body

        .d-flex.justify-content-between.align-items-center.mb-2
          h5.card-title.text-accent.mb-0(style="color:#00bfff")
            a.text-accent.text-decoration-none(href=`/users/${post.user_id}`)
              i.bi.bi-person-circle.me-2
              = post.nombre
          .d-flex.gap-2
            span.badge.bg-info.text-dark
              i.bi.bi-people-fill.me-1
              | #{post.followersCount} seguidores
            span.badge.bg-info.text-dark
              | #{post.followingCount} siguiendo

        if sessionUser && !post.isOwner
          if post.isFollowing
            form(action="/posts/unfollow" method="POST")
              input(type="hidden" name="following_id" value=post.user_id)
              button.btn.btn-sm.btn-outline-danger.mb-2(type="submit")
                i.bi.bi-person-dash.me-1
                | Dejar de seguir
          else
            form(action="/posts/follow" method="POST")
              input(type="hidden" name="following_id" value=post.user_id)
              button.btn.btn-sm.btn-outline-info.mb-2(type="submit")
                i.bi.bi-person-plus.me-1
                | Seguir

        if post.titulo
          h6.fw-bold(style="color:#00bfff")= post.titulo

        - const postImages = post.images && post.images.length ? post.images.map(image => image.url) : [post.imagen]
        if postImages.length > 1
          .carousel.slide.mb-3(id=`post-carousel-${post.id}`)
            .carousel-inner
              each imageUrl, imageIndex in postImages
                .carousel-item(class=imageIndex === 0 ? "active" : "")
                  .position-relative
                    img.d-block.w-100.rounded(src=imageUrl alt=`Imagen ${imageIndex + 1} de ${post.titulo}`)
                    if post.marca_agua
                      span.position-absolute.bottom-0.end-0.m-2.badge.bg-dark.opacity-75
                        i.bi.bi-droplet-fill.me-1
                        = post.marca_agua
            button.carousel-control-prev(type="button" data-bs-target=`#post-carousel-${post.id}` data-bs-slide="prev" aria-label="Imagen anterior")
              span.carousel-control-prev-icon
            button.carousel-control-next(type="button" data-bs-target=`#post-carousel-${post.id}` data-bs-slide="next" aria-label="Imagen siguiente")
              span.carousel-control-next-icon
        else
          .position-relative.mb-3
            img.img-fluid.rounded(src=postImages[0])
            if post.marca_agua
              span.position-absolute.bottom-0.end-0.m-2.badge.bg-dark.opacity-75
                i.bi.bi-droplet-fill.me-1
                = post.marca_agua

        if post.descripcion
          p.card-text= post.descripcion

        .d-flex.gap-2.flex-wrap.mb-2
          if post.etiquetas
            span.badge.bg-info.text-dark
              i.bi.bi-tags-fill.me-1
              = post.etiquetas
          if post.licencia === "con copyright"
            span.badge.bg-warning.text-dark
              i.bi.bi-c-circle-fill.me-1
              | Con copyright
          else
            span.badge.bg-success
              i.bi.bi-unlock-fill.me-1
              | Sin copyright

        .d-flex.align-items-center.mb-3
          i.bi.bi-star-fill.text-warning.me-1
          span #{post.ratingPromedio} / 5
          span.text-muted.ms-2 (#{post.ratingCantidad} votos)

        if sessionUser && !post.isOwner
          form.d-flex.gap-2.mb-3(action="/posts/rate" method="POST")
            input(type="hidden" name="post_id" value=post.id)
            select.form-select.form-select-sm(name="valor" style="width:80px")
              option(value="1") 1
              option(value="2") 2
              option(value="3") 3
              option(value="4") 4
              option(value="5") 5
            button.btn.btn-sm.btn-primary-custom(type="submit")
              i.bi.bi-star.me-1
              | Valorar
        else if sessionUser
          p.text-muted.small No podes valorar tu propia publicacion

        if collections && collections.length > 0
          form.d-flex.gap-2.mb-3(action="/collections/save" method="POST")
            input(type="hidden" name="post_id" value=post.id)
            select.form-select.form-select-sm(name="collection_id")
              each collection in collections
                option(value=collection.id)= collection.nombre
            button.btn.btn-sm.btn-outline-light(type="submit")
              i.bi.bi-bookmark-plus.me-1
              | Guardar

        if sessionUser && !post.isOwner
          form.mb-2(action="/interests" method="POST")
            .input-group.input-group-sm
              input(type="hidden" name="post_id" value=post.id)
              input.form-control(type="text" name="mensaje" placeholder="Mensaje para el autor...")
              button.btn.btn-primary-custom(type="submit")
                i.bi.bi-heart.me-1
                | Me interesa

        if sessionUser && !post.isOwner
          form.mb-3(action="/reports/post" method="POST")
            .input-group.input-group-sm
              input(type="hidden" name="post_id" value=post.id)
              select.form-select(name="motivo")
                option(value="contenido inapropiado") Contenido inapropiado
                option(value="copyright") Copyright
                option(value="spam") Spam
                option(value="otro") Otro
              input.form-control(type="text" name="descripcion" placeholder="Descripción...")
              button.btn.btn-outline-danger(type="submit")
                i.bi.bi-flag.me-1
                | Denunciar

        h6.text-accent
          i.bi.bi-chat-dots-fill.me-1
          | Comentarios

        if post.isOwner
          form.mb-3(action="/posts/comments/toggle" method="POST")
            input(type="hidden" name="post_id" value=post.id)
            input(type="hidden" name="cerrar" value=post.comentarios_cerrados ? "false" : "true")
            button.btn.btn-sm.btn-outline-warning(type="submit")
              if post.comentarios_cerrados
                i.bi.bi-chat-left-text.me-1
                | Abrir comentarios
              else
                i.bi.bi-chat-left-x.me-1
                | Cerrar comentarios

        if post.comments
          each comment in post.comments
            .bg-dark.rounded.p-2.mb-2.small.text-white
              .d-flex.align-items-start.justify-content-between.gap-2.mb-2
                p.mb-0.flex-grow-1
                  b= comment.nombre
                  |  #{comment.comentario}
                if comment.isOwner
                  .d-flex.gap-1.flex-shrink-0
                    button.btn.btn-sm.btn-outline-info(
                      type="button"
                      title="Editar comentario"
                      aria-label="Editar comentario"
                      data-bs-toggle="collapse"
                      data-bs-target=`#edit-comment-${comment.id}`
                      aria-controls=`edit-comment-${comment.id}`
                    )
                      i.bi.bi-pencil-square
                    form(action="/posts/comment/delete" method="POST" onsubmit="return confirm('¿Eliminar este comentario?')")
                      input(type="hidden" name="comment_id" value=comment.id)
                      button.btn.btn-sm.btn-outline-danger(type="submit" title="Eliminar comentario" aria-label="Eliminar comentario")
                        i.bi.bi-trash
              if comment.isOwner
                .collapse.mb-2(id=`edit-comment-${comment.id}`)
                  form(action="/posts/comment/edit" method="POST")
                    input(type="hidden" name="comment_id" value=comment.id)
                    .input-group.input-group-sm
                      input.form-control(type="text" name="comentario" value=comment.comentario required)
                      button.btn.btn-primary-custom(type="submit" title="Guardar comentario" aria-label="Guardar comentario")
                        i.bi.bi-check-lg
              if sessionUser && !comment.isOwner
                form(action="/reports/comment" method="POST")
                  input(type="hidden" name="comment_id" value=comment.id)
                  .input-group.input-group-sm
                    select.form-select(name="motivo" aria-label="Motivo de denuncia")
                      option(value="contenido inapropiado") Contenido inapropiado
                      option(value="acoso") Acoso
                      option(value="spam") Spam
                      option(value="otro") Otro
                    input.form-control(type="text" name="descripcion" placeholder="Descripción...")
                    button.btn.btn-outline-danger(type="submit" title="Denunciar comentario" aria-label="Denunciar comentario")
                      i.bi.bi-flag

        if post.comentarios_cerrados
          p.text-muted.small Los comentarios están cerrados.
        else if sessionUser
          form(action="/posts/comment" method="POST")
            .input-group.input-group-sm
              input(type="hidden" name="post_id" value=post.id)
              input.form-control(type="text" name="comentario" placeholder="Escriba un comentario...")
              button.btn.btn-primary-custom(type="submit")
                i.bi.bi-send
