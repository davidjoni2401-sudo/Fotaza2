doctype html
doctype html
html
  head
    title Feed

    style.
      body {
        background-color: #1e1e2f;
        font-family: Arial, sans-serif;
        color: white;
        margin: 0;
        padding: 20px;
      }

      h1 {
        text-align: center;
        color: #00bfff;
      }

      .post {
        background-color: #2c2c3e;
        padding: 20px;
        border-radius: 10px;
        margin: 20px auto;
        width: 400px;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
      }

      img {
        width: 100%;
        border-radius: 10px;
        margin-top: 10px;
      }

      p {
        margin-top: 10px;
      }

      h3 {
        color: #00bfff;
      }

      h4 {
        margin-top: 20px;
        color: #00d4ff;
      }

      .comment {
        background-color: #3a3a50;
        padding: 10px;
        border-radius: 5px;
        margin-top: 8px;
      }

      input[type="text"] {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        border: none;
        border-radius: 5px;
        box-sizing: border-box;
      }

      button {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        background-color: #00bfff;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
      }

      button:hover {
        background-color: #009acd;
      }

      .search-form {
        width: 400px;
        margin: 0 auto 20px auto;
       }

      .image-box {
        position: relavite;
        width: 100%;
        margin-top: 10px;
      }

       .image-box img {
        width: 100%;
        border-radius: 10px;
        display: block;
      }

      .watermark {
        position: absolute;
        right: 12px;
        bottom: 12px;
        color: white;
        background: rgba(0, 0, 0, 0.45);
        padding: 6px 10px;
        border-radius: 5px;
        font-weight: bold; 
      }


  body

    h1 Feed de Publicaciones

    form(action="/posts/feed" method="GET")
      input(
        type="text"
        name="busqueda"
        placeholder="Buscar publicaciones"
      ) 
      button(type="submit") Buscar 

    each post in posts

      .post

        h3= post.nombre

        h4= post.titulo 

        p Seguidores: #{post.followersCount}
        p Siguiendo: #{post.followingCount}

        if !post.isOwner
          if post.isFollowing
            p Siguiendo a #{post.nombre}

            form(action="/posts/unfollow" method="POST")
              input(type="hidden" name="following_id" value=post.user_id)
              button(type="submit") Dejar de seguir
          else
            form(action="/posts/follow" method="POST")
              input(type="hidden" name="following_id" value=post.user_id)
              button(type="submit") Seguir

        .image-box
            .image-box
              img(src=`/uploads/${post.imagen}`)

            if post.marca_agua
              span.watermark= post.marca_agua

        p= post.descripcion

        if post.etiquetas 
          p Etiquetas: #{post.etiquetas}

        p Licencia: #{post.licencia}

        if post.marca_agua
          p Marca de agua: #{post.marca_agua}

        p Valoración: #{post.ratingPromedio} / 5 (#{post.ratingCantidad} votos)

        if !post.isOwner
          form(action="/posts/rate" method="POST")
            input(type="hidden" name="post_id" value=post.id)
            select(name="valor")
              option(value="1") 1
              option(value="2") 2
              option(value="3") 3
              option(value="4") 4
              option(value="5") 5
            button(type="submit") Valorar
        else 
          p No podes valorar tu propia publicacion

        if collections && collections.length > 0
          form(action="/collections/save" method="POST")
            input(type="hidden" name="post_id" value=post.id)

            select(name="collection_id")
              each collection in collections
                option(value=collection.id)= collection.nombre

            button(type="submit") Guardar en colección
            
        if !post.isOwner
          form(action="/interests" method="POST")
            input(type="hidden" name="post_id" value=post.id)
            input(
              type="text"
              name="mensaje"
              placeholder="Mensaje para el autor"
             )
            button(type="submit") Me interesa

        if !post.isOwner
          form(action="/reports/post" method="POST")
            input(type="hidden" name="post_id" value=post.id)

            select(name="motivo")
              option(value="contenido inapropiado") Contenido inapropiado
              option(value="copyright") Copyright
              option(value="spam") Spam
              option(value="otro") Otro

            input(
              type="text"
              name="descripcion"
              placeholder="Descripción de la denuncia"
            )

            button(type="submit") Denunciar

        h4 Comentarios

        if post.comments

          each comment in post.comments

            .comment

              p
                b #{comment.nombre}:
                |  #{comment.comentario}
         

        form(action="/posts/comment" method="POST")

          input(
            type="hidden"
            name="post_id"
            value=post.id
          )

          input(
            type="text"
            name="comentario"
            placeholder="Escribí un comentario"
          )

          button(type="submit") Comentar