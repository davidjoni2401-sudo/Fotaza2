extends layout

block content
  h2.text-accent.mb-4
    i.bi.bi-heart-fill.me-2
    | Usuarios interesados en tus publicaciones

  if interests.length === 0
    .alert.alert-secondary
      i.bi.bi-heart.me-2
      | No hay usuarios interesados todavía
  else
    .row
      each interest in interests
        .col-md-6.mb-4
          .card.card-custom.p-3
            .row
              .col-4
                - const interestImage = interest.post_imagen.startsWith("http") ? interest.post_imagen : `/uploads/${interest.post_imagen}`
                img.img-fluid.rounded(src=interestImage)
              .col-8
                h5.text-accent= interest.post_titulo
                p.mb-1
                  i.bi.bi-person-fill.me-1
                  b= interest.interesado_nombre
                p.mb-1.small
                  i.bi.bi-envelope-fill.me-1
                  = interest.interesado_email
                if interest.mensaje
                  .alert.alert-dark.mt-2.p-2.small
                    i.bi.bi-chat-quote-fill.me-1
                    = interest.mensaje
                a.btn.btn-sm.btn-outline-info.mt-2(href=`/messages?user_id=${interest.user_id}`)
                  i.bi.bi-reply-fill.me-1
                  | Responder
