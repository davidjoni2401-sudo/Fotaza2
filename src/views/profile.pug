extends layout

block content
  .d-flex.justify-content-between.align-items-start.flex-wrap.gap-3.mb-4
    .d-flex.align-items-center.gap-3
      if user.foto_perfil
        img.rounded-circle(src=user.foto_perfil alt=`Foto de ${user.nombre}` style="width:80px;height:80px;object-fit:cover")
      else
        i.bi.bi-person-circle.text-accent(style="font-size:5rem")
      div
        h2.mb-1= user.nombre
        .d-flex.gap-2
          span.badge.bg-info.text-dark #{followersCount} seguidores
          span.badge.bg-info.text-dark #{followingCount} siguiendo
    if sessionUser && !isOwner
      .d-flex.gap-2
        a.btn.btn-outline-info(href=`/messages?user_id=${user.id}`)
          i.bi.bi-envelope.me-1
          | Mensaje
        if isFollowing
          form(action="/posts/unfollow" method="POST")
            input(type="hidden" name="following_id" value=user.id)
            button.btn.btn-outline-danger(type="submit")
              i.bi.bi-person-dash.me-1
              | Dejar de seguir
        else
          form(action="/posts/follow" method="POST")
            input(type="hidden" name="following_id" value=user.id)
            button.btn.btn-primary-custom(type="submit")
              i.bi.bi-person-plus.me-1
              | Seguir

  h4.mb-3 Publicaciones

  if posts.length === 0
    .alert.alert-secondary Este usuario todavía no tiene publicaciones visibles.
  else
    .row.g-3
      each post in posts
        .col-sm-6.col-lg-4
          .card.card-custom.h-100
            - const profileImage = post.images && post.images.length ? post.images[0].url : post.imagen
            img.card-img-top(src=profileImage alt=post.titulo || "Publicación" style="height:220px;object-fit:cover")
            .card-body
              h5.card-title= post.titulo || "Sin título"
              if post.descripcion
                p.card-text= post.descripcion
              if post.licencia === "con copyright"
                span.badge.bg-warning.text-dark Con copyright
              else
                span.badge.bg-success Sin copyright
