extends layout

block content
  .row.justify-content-center
    .col-md-6
      .card.card-custom.p-4
        h3.text-accent.text-center.mb-4
          i.bi.bi-plus-circle-fill.me-2
          | Nueva Publicación
        form(action="/posts/create" method="POST" enctype="multipart/form-data")
          .mb-3
            label.form-label Título
            input.form-control(type="text" name="titulo" maxlength="150" placeholder="Título de la publicación" required)
          .mb-3
            label.form-label Imágenes
            input.form-control(type="file" name="imagenes" accept="image/jpeg,image/png,image/gif,image/webp" multiple required)
            small.text-muted Podés seleccionar entre 1 y 5 imágenes.
          .mb-3
            label.form-label Descripción (opcional)
            textarea.form-control(name="descripcion" rows="3" placeholder="Descripción de la imagen...")
          .mb-3
            label.form-label Etiquetas
            input.form-control(type="text" name="etiquetas" maxlength="500" placeholder="naturaleza, viajes, arte..." required)
          .mb-3
            label.form-label Licencia
            select.form-select(name="licencia" id="licenciaSelect")
              option(value="sin copyright") Sin copyright
              option(value="con copyright") Con copyright
          .mb-3#marcaAguaDiv(style="display:none")
            label.form-label Texto de marca de agua
            input.form-control(type="text" name="marca_agua" placeholder="Ej: © Mi Nombre 2026")
          button.btn.btn-primary-custom.w-100(type="submit")
            i.bi.bi-cloud-upload-fill.me-2
           
        script.
          const licenciaSelect = document.getElementById('licenciaSelect');
          const marcaAguaDiv = document.getElementById('marcaAguaDiv');
          licenciaSelect.addEventListener('change', function() {
            marcaAguaDiv.style.display = this.value === 'con copyright' ? 'block' : 'none';
            if (this.value !== 'con copyright') {
              marcaAguaDiv.querySelector('input').value = '';
            }
          });
